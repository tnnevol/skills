{
  "name": "@tnnevol/halo-cli",
  "version": "1.0.0",
  "description": "CLI tool to manage blog posts in Halo CMS",
  "bin": {
    "halo-cli": "./index.js"
  },
  "scripts": {
    "build": "make build-all",
    "bump": "bumpp",
    "bump:patch": "bumpp patch -y",
    "bump:minor": "bumpp minor -y",
    "bump:major": "bumpp major -y",
    "release": "bumpp patch -y --execute \"npm publish\""
  },
  "files": [
    "index.js",
    "bin/"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tnnevol/skills.git",
    "directory": "apps/halo"
  },
  "author": "tnnevol",
  "devDependencies": {
    "bumpp": "^11.0.1"
  }
}
